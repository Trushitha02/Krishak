<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Krishak — Crop Calendar</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Noto+Sans+Telugu:wght@400;500;600&family=Noto+Sans+Devanagari:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="shared.css">
<style>
.mini-cal { display:grid; grid-template-columns:repeat(7,1fr); gap:4px; margin-top:0.75rem; }
.cal-day-header { text-align:center; font-size:0.72rem; font-weight:600; color:var(--text-lt); padding:4px 0; }
.cal-day {
  aspect-ratio:1; display:flex; align-items:center; justify-content:center;
  font-size:0.8rem; border-radius:8px; cursor:pointer; border:1px solid transparent;
  transition:all 0.15s; color:var(--text);
}
.cal-day:hover { background:var(--leaf-bg); border-color:var(--leaf-lt); }
.cal-day.today { background:var(--leaf); color:white; font-weight:700; }
.cal-day.has-event { position:relative; }
.cal-day.has-event::after { content:''; position:absolute; bottom:3px; left:50%; transform:translateX(-50%); width:4px; height:4px; border-radius:50%; background:var(--wheat); }
.cal-day.other-month { color:var(--border); }
.cal-day.selected { background:var(--wheat-lt); border-color:var(--wheat); font-weight:600; }

.crop-season-card {
  border-radius:12px; border:1px solid var(--border);
  overflow:hidden; margin-bottom:0.75rem;
  transition:transform 0.2s, box-shadow 0.2s;
}
.crop-season-card:hover { transform:translateY(-2px); box-shadow:var(--shadow-md); }
.season-header {
  display:flex; align-items:center; gap:12px;
  padding:12px 14px; cursor:pointer;
}
.season-body { padding:12px 14px; border-top:1px solid var(--border); background:#fdfaf6; }
.stage-pill {
  display:inline-flex; align-items:center; gap:5px;
  padding:4px 10px; border-radius:20px; font-size:0.78rem; font-weight:600;
  margin:3px; border:1px solid transparent;
}
</style>
</head>
<body>
<nav id="main-nav"></nav>

<div class="page">
  <div class="page-header fade-up">
    <div class="page-title">📅 <span id="title-text"></span></div>
    <div class="page-subtitle" id="subtitle-text"></div>
  </div>

  <div class="grid-2">
    <!-- Calendar Widget -->
    <div class="card fade-up">
      <div class="card-header">
        <div class="card-title">📆 <span id="month-label"></span></div>
        <div style="display:flex;gap:6px;">
          <button class="btn btn-secondary" style="padding:4px 10px;" onclick="prevMonth()">‹</button>
          <button class="btn btn-secondary" style="padding:4px 10px;" onclick="nextMonth()">›</button>
        </div>
      </div>
      <div class="card-body">
        <div class="mini-cal" id="mini-cal"></div>
        <div id="selected-info" style="margin-top:1rem;padding:10px;background:var(--cream);border-radius:8px;font-size:0.85rem;"></div>
      </div>
    </div>

    <!-- AI Schedule Advisor -->
    <div class="card fade-up delay-1">
      <div class="card-header">
        <div class="card-title">🤖 AI Schedule Advisor</div>
      </div>
      <div class="card-body">
        <div class="form-group">
          <label class="form-label">Your Crop</label>
          <select class="form-select" id="cal-crop">
            <option value="rice">🌾 Rice / Paddy</option>
            <option value="cotton">🌿 Cotton</option>
            <option value="maize">🌽 Maize / Corn</option>
            <option value="chilli">🌶️ Chilli</option>
            <option value="sugarcane">🍬 Sugarcane</option>
            <option value="groundnut">🥜 Groundnut</option>
            <option value="soybean">🫘 Soybean</option>
            <option value="wheat">🌾 Wheat</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Sowing Date</label>
          <input type="date" class="form-input" id="cal-date">
        </div>
        <div class="form-group">
          <label class="form-label">Region</label>
          <select class="form-select" id="cal-region">
            <option value="telangana">Telangana / AP</option>
            <option value="maharashtra">Maharashtra</option>
            <option value="punjab">Punjab</option>
            <option value="up">Uttar Pradesh</option>
            <option value="gujarat">Gujarat</option>
            <option value="karnataka">Karnataka</option>
          </select>
        </div>
        <button class="btn btn-primary" style="width:100%;" onclick="generateSchedule()">
          🤖 Generate AI Schedule
        </button>
        <div id="ai-cal-resp" class="ai-response" style="display:none;margin-top:0.75rem;"></div>
      </div>
    </div>
  </div>

  <!-- Visual Crop Schedules -->
  <div class="card fade-up delay-2" style="margin-top:1rem;">
    <div class="card-header">
      <div class="card-title">🌱 Crop Growth Stages</div>
      <select class="form-select" id="stage-season" onchange="renderStages()" style="width:auto;padding:5px 10px;font-size:0.82rem;">
        <option value="kharif">Kharif (Jun–Nov)</option>
        <option value="rabi">Rabi (Nov–Apr)</option>
        <option value="zaid">Zaid (Mar–Jun)</option>
      </select>
    </div>
    <div class="card-body" id="stage-body"></div>
  </div>

  <!-- Upcoming Tasks -->
  <div class="card fade-up delay-3" style="margin-top:1rem;">
    <div class="card-header">
      <div class="card-title">✅ Upcoming Farm Tasks</div>
      <span class="badge badge-wheat">Next 7 days</span>
    </div>
    <div class="card-body" id="upcoming-tasks"></div>
  </div>
</div>

<script src="shared.js"></script>
<script>
let calYear = new Date().getFullYear();
let calMonth = new Date().getMonth();
const today = new Date();

const CROP_STAGES = {
  kharif: [
    { crop:'🌾 Rice', plant:[0,2], veg:[2,6], flower:[6,9], harvest:[9,12], dur:'120-150 days', color:'#3a6b35' },
    { crop:'🌿 Cotton', plant:[1,3], veg:[3,7], flower:[7,10], harvest:[10,14], dur:'160-180 days', color:'#5a9a52' },
    { crop:'🌽 Maize', plant:[0,1], veg:[1,4], flower:[4,6], harvest:[6,8], dur:'85-95 days', color:'#d97706' },
    { crop:'🫘 Soybean', plant:[0,2], veg:[2,5], flower:[5,7], harvest:[7,9], dur:'90-100 days', color:'#8c5e3c' },
  ],
  rabi: [
    { crop:'🌾 Wheat', plant:[0,1], veg:[1,5], flower:[5,7], harvest:[7,9], dur:'100-120 days', color:'#e8c97a' },
    { crop:'🥜 Groundnut', plant:[0,2], veg:[2,5], flower:[5,8], harvest:[8,10], dur:'105-125 days', color:'#b5451b' },
    { crop:'🫛 Chickpea', plant:[0,2], veg:[2,5], flower:[5,7], harvest:[7,9], dur:'95-105 days', color:'#5c3d2b' },
  ],
  zaid: [
    { crop:'🍉 Watermelon', plant:[0,1], veg:[1,3], flower:[3,5], harvest:[5,7], dur:'75-90 days', color:'#2e7bb5' },
    { crop:'🥒 Cucumber', plant:[0,1], veg:[1,3], flower:[3,4], harvest:[4,6], dur:'55-65 days', color:'#3a6b35' },
  ]
};

const TASKS = [
  { day:0, task: getLang()==='te'?'పత్తి పొలంలో నీళ్ళు పెట్టండి':getLang()==='hi'?'कपास में सिंचाई करें':'Irrigate cotton field', icon:'💧', priority:'high' },
  { day:1, task: getLang()==='te'?'వరి నాట్లకు ఎరువు వేయండి':getLang()==='hi'?'धान में खाद डालें':'Apply urea to paddy nursery', icon:'🧪', priority:'medium' },
  { day:2, task:'Check for stem borer in rice', icon:'🔍', priority:'low' },
  { day:3, task:'Spray fungicide on cotton', icon:'🌿', priority:'high' },
  { day:4, task:'Soil moisture check — all fields', icon:'📊', priority:'medium' },
  { day:5, task:'Market visit — sell Kharif produce', icon:'🏪', priority:'low' },
  { day:6, task:'Prepare nursery beds for Rabi season', icon:'🌱', priority:'medium' },
];

document.addEventListener('DOMContentLoaded', () => {
  injectNav('calendar');
  document.getElementById('title-text').textContent = t('cropCalendar');
  document.getElementById('subtitle-text').textContent = getLang()==='te' ? 'మీ పంట కార్యక్రమాన్ని ప్లాన్ చేసుకోండి' : getLang()==='hi' ? 'अपनी फसल की योजना बनाएं' : 'Plan and track your agricultural activities';
  document.getElementById('cal-date').valueAsDate = new Date();
  renderCalendar();
  renderStages();
  renderTasks();
});

function renderCalendar() {
  const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  document.getElementById('month-label').textContent = `${monthNames[calMonth]} ${calYear}`;
  const days = ['Su','Mo','Tu','We','Th','Fr','Sa'];
  const firstDay = new Date(calYear, calMonth, 1).getDay();
  const daysInMonth = new Date(calYear, calMonth+1, 0).getDate();
  const daysInPrev = new Date(calYear, calMonth, 0).getDate();

  const farmEvents = [3,8,12,15,20,25,28];
  let html = days.map(d => `<div class="cal-day-header">${d}</div>`).join('');

  for (let i=0; i<firstDay; i++) {
    html += `<div class="cal-day other-month">${daysInPrev - firstDay + i + 1}</div>`;
  }
  for (let d=1; d<=daysInMonth; d++) {
    const isToday = d===today.getDate() && calMonth===today.getMonth() && calYear===today.getFullYear();
    const hasEv = farmEvents.includes(d);
    html += `<div class="cal-day ${isToday?'today':''} ${hasEv?'has-event':''}" onclick="selectDay(${d})">${d}</div>`;
  }
  const remaining = 42 - firstDay - daysInMonth;
  for (let i=1; i<=remaining; i++) {
    html += `<div class="cal-day other-month">${i}</div>`;
  }
  document.getElementById('mini-cal').innerHTML = html;

  const info = document.getElementById('selected-info');
  info.innerHTML = `<strong>Today:</strong> ${today.toLocaleDateString('en-IN',{weekday:'long',month:'long',day:'numeric'})} — Click a date to see farm events`;
}

function selectDay(d) {
  document.querySelectorAll('.cal-day').forEach(el => el.classList.remove('selected'));
  event.target.classList.add('selected');
  const farmEvents = { 3:'Fertilizer application', 8:'Irrigation scheduled', 12:'Pesticide spray', 15:'Market day', 20:'Soil test', 25:'Harvesting begins', 28:'Seed procurement' };
  const ev = farmEvents[d];
  const info = document.getElementById('selected-info');
  if (ev) {
    info.innerHTML = `<span class="badge badge-green">📅 ${ev}</span> — ${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
  } else {
    info.innerHTML = `No events on ${String(d).padStart(2,'0')}/${String(calMonth+1).padStart(2,'0')}/${calYear}`;
  }
}

function prevMonth() { calMonth--; if(calMonth<0){calMonth=11;calYear--;} renderCalendar(); }
function nextMonth() { calMonth++; if(calMonth>11){calMonth=0;calYear++;} renderCalendar(); }

function renderStages() {
  const season = document.getElementById('stage-season').value;
  const crops = CROP_STAGES[season];
  const totalWeeks = 16;
  const segColors = ['#3a6b35','#5a9a52','#e8c97a','#b5451b'];
  const segLabels = [t('planting'), t('vegetative'), t('flowering'), t('harvest')];

  document.getElementById('stage-body').innerHTML = crops.map(crop => {
    const segs = [
      { from: crop.plant[0], to: crop.plant[1] },
      { from: crop.veg[0],   to: crop.veg[1]   },
      { from: crop.flower[0],to: crop.flower[1] },
      { from: crop.harvest[0],to: crop.harvest[1]},
    ];
    const bars = segs.map((s, i) => {
      const pct = ((s.to - s.from) / totalWeeks * 100).toFixed(1);
      return `<div class="timeline-seg" style="width:${pct}%;background:${segColors[i]};${i===2?'color:var(--soil)':''}" title="${segLabels[i]}">${pct>6?segLabels[i]:''}</div>`;
    }).join('');
    const spacer = segs[0].from / totalWeeks * 100;
    return `
      <div class="crop-season-card" style="border-left:4px solid ${crop.color}">
        <div class="season-header" style="background:#fdfaf6">
          <span style="font-size:1.3rem;">${crop.crop.split(' ')[0]}</span>
          <div style="flex:1">
            <div style="font-weight:600;color:var(--soil);font-size:0.9rem;">${crop.crop}</div>
            <div style="font-size:0.75rem;color:var(--text-lt)">Duration: ${crop.dur}</div>
          </div>
          <span class="badge badge-wheat">Week 1–${totalWeeks}</span>
        </div>
        <div class="season-body">
          <div style="display:flex;font-size:0.72rem;color:var(--text-lt);margin-bottom:4px;justify-content:space-between;">
            <span>Week 1</span><span>Week 8</span><span>Week 16+</span>
          </div>
          <div class="timeline-bar">
            <div style="width:${spacer}%;background:var(--border);"></div>
            ${bars}
          </div>
          <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:4px;">
            ${segLabels.map((l,i)=>`<span class="stage-pill" style="background:${segColors[i]}22;border-color:${segColors[i]};color:${segColors[i]}">${l}</span>`).join('')}
          </div>
        </div>
      </div>
    `;
  }).join('');
}

function renderTasks() {
  const now = new Date();
  document.getElementById('upcoming-tasks').innerHTML = TASKS.map(task => {
    const d = new Date(now);
    d.setDate(d.getDate() + task.day);
    const dayLabel = task.day === 0 ? 'Today' : task.day === 1 ? 'Tomorrow' : d.toLocaleDateString('en-IN',{weekday:'short',month:'short',day:'numeric'});
    const pColors = { high:'var(--rust)', medium:'var(--amber)', low:'var(--leaf)' };
    return `
      <div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px dashed var(--border);">
        <span style="font-size:1.3rem;">${task.icon}</span>
        <div style="flex:1">
          <div style="font-size:0.9rem;font-weight:600;color:var(--text)">${task.task}</div>
          <div style="font-size:0.78rem;color:var(--text-lt)">${dayLabel}</div>
        </div>
        <span class="badge" style="background:${pColors[task.priority]}22;color:${pColors[task.priority]}">${task.priority}</span>
      </div>
    `;
  }).join('');
}

async function generateSchedule() {
  const crop = document.getElementById('cal-crop').value;
  const date = document.getElementById('cal-date').value;
  const region = document.getElementById('cal-region').value;
  const resp = document.getElementById('ai-cal-resp');
  resp.style.display = 'block';
  resp.innerHTML = '<div class="ai-typing"><span></span><span></span><span></span></div>';
  const answer = await callAI(
    `Create a detailed crop calendar for ${crop} sown on ${date} in ${region}, India. List key dates for each growth stage, irrigation schedule, fertilizer application, and pest management. Be concise and practical.`
  );
  resp.textContent = answer;
}
</script>
</body>
</html>
